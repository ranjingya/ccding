# ccding 配置模板：复制为 .env 后填写。仅飞书通道，无 Telegram / 无声音。

# ========== 飞书自定义应用 ==========
# 飞书开放平台创建「自定义应用」→ 开发者后台 → 凭证与基础信息 获取
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 接收人标识：你的 open_id（私聊机器人）或群 chat_id
# 获取 open_id：配好上面两项后运行 `uv run python -m ccding.scripts.setup_feishu`，给机器人发一条消息，脚本会打印
FEISHU_RECEIVE_ID=ou_xxxxxxxxxxxxxxxxxxxxxxxx
# 接收人类型：open_id（私聊）或 chat_id（群）
FEISHU_RECEIVE_ID_TYPE=open_id

# ========== 通知通道开关 ==========
# 两条通道各自可独立开关（true/false，默认只开飞书）。只想用飞书就关桌面，反之亦然。
CCDING_FEISHU_ENABLED=true
CCDING_DESKTOP_ENABLED=false

# ========== 授权行为 ==========
# 钩子内部等待远程点击的上限秒数，应小于 settings.json 钩子 timeout(600)，给退出留余量
APPROVAL_TIMEOUT=290

# ========== Windows 桌面通知 ==========
# 自定义 AUMID；运行 `uv run python -m ccding.scripts.register_win_aumid` 注册同一个值
WIN_AUMID=ccding.claudecode.approval

# ========== 可选：工具分类覆盖（逗号分隔，通常无需改）==========
# CCDING_EDIT_TOOLS=Edit,Write,MultiEdit,NotebookEdit
# CCDING_READONLY_TOOLS=Read,Grep,Glob,NotebookRead,LS,TodoWrite
# 已在 settings.json 的 permissions.allow 永久允许、却仍被推送的工具，填到这里手动屏蔽
# CCDING_ALWAYS_ALLOW=

# ========== 可选：日志 ==========
# 日志固定写 stderr（不污染钩子 stdout）；下面可调级别或额外落文件
# CCDING_LOG_LEVEL=INFO
# CCDING_LOG_FILE=D:/code/ccding/ccding.log
